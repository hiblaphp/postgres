{
    "name": "hiblaphp/postgres",
    "description": "High Performance Pure Non Blocking Postgre Driver",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Hibla\\Postgres\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "hiblaphp/event-loop": "^1.0",
        "hiblaphp/promise": "^1.0",
        "hiblaphp/async": "^1.0",
        "hiblaphp/cache": "^1.0",
        "hiblaphp/sql":"^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.10",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/extension-installer": "^1.4",
        "mockery/mockery": "^1.6"
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "test:pg15": [
            "@putenv POSTGRES_PORT=5443",
            "@putenv POSTGRES_SSL_PORT=5444",
            "./vendor/bin/pest --compact"
        ],
        "test:pg16": [
            "@putenv POSTGRES_PORT=5445",
            "@putenv POSTGRES_SSL_PORT=5446",
            "./vendor/bin/pest --compact"
        ],
        "test:pg17": [
            "@putenv POSTGRES_PORT=5447",
            "@putenv POSTGRES_SSL_PORT=5448",
            "./vendor/bin/pest --compact"
        ],
        "test:pg18": [
            "@putenv POSTGRES_PORT=5449",
            "@putenv POSTGRES_SSL_PORT=5450",
            "./vendor/bin/pest --compact"
        ],
        "test:all": [
            "@test:pg15",
            "@test:pg16",
            "@test:pg17",
            "@test:pg18"
        ],
        "format": "./vendor/bin/pint",
        "format-test": "./vendor/bin/pint --test",
        "analyze": "./vendor/bin/phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    }
}